{
    "name": "brackets-selection-redux",
    "displayName": "Brackets Selection Scope",
    "description": "Select code between any brackets scopes",
    "version": "0.2.10",
    "publisher": "pit00",
    "icon": "icon.png",
    "engines": {
        "vscode": "^1.34.0"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/pit00/vscode-bracket-select-plus.git"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [],
    "extensionKind":["workspace"],
    "main": "./out/src/bracketSelectMain",
    "contributes": {
        "commands": [
            {
                "command": "brackets-selection-plus.select",
                "title": "Brackets Select"
            },
            {
                "command": "brackets-selection-plus.select-include",
                "title": "Brackets Included Select"
            }
        ],
        "keybindings": [
            {
                "command": "brackets-selection-plus.select",
                "key": "alt+a",
                "when": "editorTextFocus"
            },
            {
                "command": "brackets-selection-plus.select-include",
                "key": "ctrl+alt+a",
                "when": "editorTextFocus"
            }
        ],
        "configuration": {
            "title": "Brackets Selection",
            "properties": {
                "bracketsSelection.maxScanLines": {
                    "type": "number",
                    "default": 80,
                    "description": "Lines to scan above and below cursor"
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "lint": "tslint -p ./",
        "watch": "tsc -watch -p ./"
    },
    "devDependencies": {
        "@types/node": "^12.12.0",
        "@types/vscode": "^1.34.0",
        "tslint": "^5.19.0",
        "typescript": "^4.9.4"
    },
    "dependencies": {}
}
